  "graph": [
    {
      "id": "ico:PathosformelnScheme",
      "type": "skos:ConceptScheme",
      "label": "Pathosformeln da Iconocracia (PPGD/UFSC)",
      "definition": "Esquema SKOS das seis fórmulas de pathos identificadas no corpus iconocrático: 1800–2000, Brasil + Europa + EUA.",
      "dc:creator": "Ana Vanzin",
      "created": "2026"
    },
    {
      "id": "ico:libertasArmata",
      "type": [
        "skos:Concept",
        "ico:Pathosformel"
      ],
      "inScheme": "ico:PathosformelnScheme",
      "label": "Libertas Armata",
      "altLabel": "Armed Liberty",
      "definition": "Fórmula da figura feminina em movimento militante: braço erguido, pé avançado, arma ou estandarte em punho. Pathos da insurgência fundadora.",
      "exactMatch": [
        "iconclass:44B113",
        "iconclass:11M3",
        "wd:Q47340"
      ]
    },
    {
      "id": "ico:respublicaCoroada",
      "type": [
        "skos:Concept",
        "ico:Pathosformel"
      ],
      "inScheme": "ico:PathosformelnScheme",
      "label": "Respublica Coroada",
      "altLabel": "Crowned Respublica",
      "definition": "Fórmula da Marianne/República sentada ou ereta, drapejada, com barrete frígio, louros ou diadema. Pathos da legitimidade civil em repouso.",
      "exactMatch": [
        "iconclass:44B191",
        "iconclass:11M41",
        "wd:Q170509"
      ]
    },
    {
      "id": "ico:justitiaSerena",
      "type": [
        "skos:Concept",
        "ico:Pathosformel"
      ],
      "inScheme": "ico:PathosformelnScheme",
      "label": "Justitia Serena",
      "altLabel": "Serene Justice",
      "definition": "Fórmula da Justiça com balança e espada (frequentemente vendada), corpo idealizado, postura estática. Pathos da imparcialidade calcificada.",
      "exactMatch": [
        "iconclass:44G212",
        "iconclass:11M312",
        "wd:Q3231690"
      ]
    },
    {
      "id": "ico:matriaDomestica",
      "type": [
        "skos:Concept",
        "ico:Pathosformel"
      ],
      "inScheme": "ico:PathosformelnScheme",
      "label": "Matria Doméstica",
      "altLabel": "Domestic Mother-Land",
      "definition": "Fórmula da figura agrária, maternal, pedagógica — sentada com criança, espigas, alfaia ou livro. Pathos da reprodução naturalizada.",
      "exactMatch": [
        "iconclass:11H(MARIANNE)",
        "iconclass:44A6",
        "wd:Q174658"
      ]
    },
    {
      "id": "ico:imperiumFeminae",
      "type": [
        "skos:Concept",
        "ico:Pathosformel"
      ],
      "inScheme": "ico:PathosformelnScheme",
      "label": "Imperium Feminae",
      "altLabel": "Female Empire",
      "definition": "Fórmula da Britannia/Germania/Columbia armada, com elmo, escudo, tridente, leão. Pathos do poder imperial vestido de feminilidade marcial.",
      "exactMatch": [
        "iconclass:44B121",
        "iconclass:11M3",
        "wd:Q188909"
      ]
    },
    {
      "id": "ico:contraAlegoria",
      "type": [
        "skos:Concept",
        "ico:Pathosformel"
      ],
      "inScheme": "ico:PathosformelnScheme",
      "label": "Contra-Alegoria",
      "altLabel": "Counter-Allegory",
      "definition": "Fórmula da figura sátira, deformada, deserotizada ou ridicularizada — caricatura, alegoria ferida, alegoria desnudada. Pathos da fissura crítica.",
      "exactMatch": [
        "iconclass:49C2",
        "iconclass:44B62",
        "wd:Q221409"
      ]
    },
