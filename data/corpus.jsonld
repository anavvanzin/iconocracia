  "name": "Corpus Iconocracia · Alegoria Feminina na Cultura Jurídica (1559–1970)",
  "dc:creator": "Ana Vanzin · PPGD/UFSC",
  "created": "2026",
  "dc:license": "https://creativecommons.org/licenses/by-nc/4.0/",
  "schema:about": "Female allegory in legal-political iconography, 1800-2000",
  "ico:specimenCount": 30,
  "ico:pathosformelnCount": 6,
  "ico:edgeCount": 10,
  "ico:version": "0.1.0-jsonld-migration",
